# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional. Supports image + text diagnosis. Use a model available to your API key.
GEMINI_MODEL="gemini-3.1-flash-lite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="MY_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# ─── Stripe Billing Configuration ──────────────────────────────────────────
# STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET are server-only and must never be
# exposed to client code. Price IDs come from recurring Prices you create for
# the Pro ($29/mo) and Enterprise ($149/mo) Products in the Stripe Dashboard.
STRIPE_SECRET_KEY="sk_test_MY_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_MY_STRIPE_WEBHOOK_SECRET"
STRIPE_PRICE_ID_PRO="price_MY_STRIPE_PRO_PRICE_ID"
STRIPE_PRICE_ID_ENTERPRISE="price_MY_STRIPE_ENTERPRISE_PRICE_ID"

# PENDING_SIGNUP_SECRET: Server-only key used to encrypt passwords held
# temporarily in the pending_signups table while a user completes email OTP
# verification. Generate with: openssl rand -base64 32
PENDING_SIGNUP_SECRET="MY_PENDING_SIGNUP_SECRET"

# ─── Email / SMTP Configuration (Gmail App Password) ───────────────────────────
# IMPORTANT: These MUST also be set as environment variables in your Cloud Run
# service. The .env file is NOT used in production on Cloud Run.
#
# How to get a Gmail App Password:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Enable 2-Step Verification on your Google account (required)
#   3. Create a new App Password → select "Mail" + "Other (custom name)"
#   4. Copy the 16-character password (remove spaces) and paste it below.
#
# How to set these in Cloud Run:
#   gcloud run services update YOUR_SERVICE_NAME \
#     --region YOUR_REGION \
#     --update-env-vars SMTP_USER=you@gmail.com,SMTP_PASS=yourapppassword,SMTP_FROM="AgriScan AI <you@gmail.com>"
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="your_16_char_app_password"
SMTP_FROM="AgriScan AI <your_gmail@gmail.com>"
